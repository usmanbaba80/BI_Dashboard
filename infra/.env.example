# Copy to .env and fill in values before: docker compose up -d
# -----------------------------------------------------------------------------
# External warehouse PostgreSQL (private network — use DB VPS private IP / DNS)
# -----------------------------------------------------------------------------
WAREHOUSE_PG_HOST=10.0.0.10
WAREHOUSE_PG_PORT=5432
WAREHOUSE_PG_USER=analytics
WAREHOUSE_PG_PASSWORD=change-me
WAREHOUSE_PG_DATABASE=analytics_db
# Default schema for dbt models (create in Postgres if missing)
DBT_SCHEMA=silver

# -----------------------------------------------------------------------------
# Dagster internal metadata DB (separate from the warehouse; stays in Docker)
# -----------------------------------------------------------------------------
DAGSTER_POSTGRES_USER=dagster
DAGSTER_POSTGRES_PASSWORD=change-me-dagster
DAGSTER_POSTGRES_DB=dagster

# -----------------------------------------------------------------------------
# dbt-Workbench metadata DB + runtime paths
# -----------------------------------------------------------------------------
DBTWB_POSTGRES_USER=dbtwb
DBTWB_POSTGRES_PASSWORD=change-me-dbtwb
DBTWB_POSTGRES_DB=dbt_workbench

# These are container paths for dbt-Workbench backend.
DBTWB_DBT_PROJECT_PATH=/workspace/dbt_project
DBTWB_DBT_ARTIFACTS_PATH=/workspace/dbt_artifacts
DBTWB_GIT_REPOS_BASE_PATH=/workspace/repos

# UI on host :3001, API on host :8001
DBTWB_VITE_API_BASE_URL=http://localhost:8001

# Optional auth hardening for workbench
DBTWB_AUTH_ENABLED=false
DBTWB_SINGLE_PROJECT_MODE=true
DBTWB_JWT_SECRET_KEY=change_me

# -----------------------------------------------------------------------------
# Contabo Object Storage (S3-compatible) — backups, artifacts, or future lake files
# Region endpoints: https://help.contabo.com/.../s3-connection-settings
#   EU: https://eu2.contabostorage.com
#   Singapore: https://sin1.contabostorage.com
#   US: https://usc1.contabostorage.com
# -----------------------------------------------------------------------------
S3_ENDPOINT_URL=https://eu2.contabostorage.com
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=your-bucket-name
# Optional; many S3 clients want a region string even for Contabo
S3_REGION=us-east-1

# -----------------------------------------------------------------------------
# Airbyte (run separately with abctl — see comments in docker-compose.yml)
# If you use Basic Auth on Airbyte proxy:
# AIRBYTE_BASIC_AUTH_USER=
# AIRBYTE_BASIC_AUTH_PASSWORD=
# bootstrap helper env (infra/airbyte/abctl.env.example)
AIRBYTE_HOST=10.0.0.20
AIRBYTE_PORT=8000
AIRBYTE_INSECURE_COOKIES=true
